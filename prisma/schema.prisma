generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  LOAN
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  CUSTOM
}

enum PayoffStrategy {
  AVALANCHE
  SNOWBALL
  FIXED
}

enum PayeeType {
  PERSON
  BUSINESS
  INSTITUTION
  OTHER
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  payees       Payee[]
  budgets      Budget[]
  creditors    Creditor[]
  debts        Debt[]
  debtPayments DebtPayment[]
  appSettings  AppSetting[]
}

// ─────────────────────────────────────────────
// Account
// ─────────────────────────────────────────────

model Account {
  id          String      @id @default(uuid())
  name        String
  type        AccountType
  balance     Decimal     @db.Decimal(15, 2)
  currency    String      @default("EUR")
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]
  debts        Debt[]
}

// ─────────────────────────────────────────────
// Category
// ─────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String
  color     String?
  icon      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
}

// ─────────────────────────────────────────────
// Transaction
// ─────────────────────────────────────────────

model Transaction {
  id          String          @id @default(uuid())
  date        DateTime
  amount      Decimal         @db.Decimal(15, 2)
  type        TransactionType
  description String
  notes       String?
  isImported  Boolean         @default(false)
  importHash  String?         @unique // for duplicate detection on CSV import
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  userId     String
  user       User      @relation(fields: [userId], references: [id])
  accountId  String
  account    Account   @relation(fields: [accountId], references: [id])
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  payeeId    String?
  payee      Payee?    @relation(fields: [payeeId], references: [id])

  debtPayment DebtPayment? // one transaction can fund at most one debt payment
}

// ─────────────────────────────────────────────
// Payee
// ─────────────────────────────────────────────

model Payee {
  id        String    @id @default(uuid())
  name      String
  type      PayeeType
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]

  @@unique([userId, name])
}

// ─────────────────────────────────────────────
// Budget
// ─────────────────────────────────────────────

model Budget {
  id              String       @id @default(uuid())
  name            String
  amount          Decimal      @db.Decimal(15, 2)
  period          BudgetPeriod
  customStartDate DateTime? // used when period = CUSTOM
  customEndDate   DateTime?
  alertThreshold  Int          @default(80) // percentage (0-100)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
}

// ─────────────────────────────────────────────
// Creditor
// ─────────────────────────────────────────────

model Creditor {
  id          String   @id @default(uuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  website     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  debts Debt[]
}

// ─────────────────────────────────────────────
// Debt
// ─────────────────────────────────────────────

model Debt {
  id              String         @id @default(uuid())
  name            String
  originalAmount  Decimal        @db.Decimal(15, 2)
  currentBalance  Decimal        @db.Decimal(15, 2)
  interestRate    Decimal        @db.Decimal(5, 4) // e.g. 0.0525 = 5.25%
  minimumPayment  Decimal        @db.Decimal(15, 2)
  dueDay          Int? // day of month (1-31)
  payoffStrategy  PayoffStrategy @default(FIXED)
  startDate       DateTime
  expectedEndDate DateTime?
  isActive        Boolean        @default(true)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  creditorId String
  creditor   Creditor @relation(fields: [creditorId], references: [id])
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id])

  payments DebtPayment[]
}

// ─────────────────────────────────────────────
// Debt Payment (payment history per debt)
// ─────────────────────────────────────────────

model DebtPayment {
  id           String   @id @default(uuid())
  paymentDate  DateTime
  amount       Decimal  @db.Decimal(15, 2)
  principal    Decimal  @db.Decimal(15, 2) // portion reducing balance
  interest     Decimal  @db.Decimal(15, 2) // portion going to interest
  balanceAfter Decimal  @db.Decimal(15, 2)
  notes        String?
  createdAt    DateTime @default(now())

  userId        String
  user          User         @relation(fields: [userId], references: [id])
  debtId        String
  debt          Debt         @relation(fields: [debtId], references: [id])
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
}

// ─────────────────────────────────────────────
// App Settings (key-value config store)
// ─────────────────────────────────────────────

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
